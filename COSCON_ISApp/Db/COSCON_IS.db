record(stringin, "$(Sys)$(Dev)Info")
{
	field(DTYP, "stream")
	field(DESC, "Info")
	field(INP,  "@COSCON_IS.proto ReadInfo($(Chan)) $(PORT)")
    field(PINI, "1")
}


record(longin, "$(Sys)$(Dev)Uptime")
{
	field(DTYP, "stream")
	field(DESC, "Uptime")
	field(INP,  "@COSCON_IS.proto ReadUptime($(Chan)) $(PORT)")
	field(EGU,  "seconds")
	#field(SCAN, "1 second")
    field(PINI, "1")
}


record(stringin, "$(Sys)$(Dev)DeviceType")
{
	field(DTYP, "stream")
	field(DESC, "Device type")
	field(INP,  "@COSCON_IS.proto ReadDeviceType($(Chan)) $(PORT)")
    field(PINI, "1")
}


record(stringin, "$(Sys)$(Dev)FirmwareVersion")
{
	field(DTYP, "stream")
	field(DESC, "Firmware version")
	field(INP,  "@COSCON_IS.proto ReadFirmwareVersion($(Chan)) $(PORT)")
    field(PINI, "1")
}


record(stringin, "$(Sys)$(Dev)DeviceSerial")
{
	field(DTYP, "stream")
	field(DESC, "Device serial")
	field(INP,  "@COSCON_IS.proto ReadDeviceSerial($(Chan)) $(PORT)")
    field(PINI, "1")
}


record(bo, "$(Sys)$(Dev)Identify")
{
    field(DTYP, "stream")
    field(DESC, "Identify")
    field(OUT,  "@COSCON_IS.proto WriteIdentify($(Chan)) $(PORT)")
    field(ZNAM, "OFF")    # Zero state name
    field(ONAM, "ON")     # One state name
}


record(bi, "$(Sys)$(Dev)Identify_RBV")
{
    field(DTYP, "stream")
    field(DESC, "Identify RB")
    field(INP,  "@COSCON_IS.proto ReadIdentify($(Chan)) $(PORT)")
    field(ZNAM, "OFF")    # Zero state name
    field(ONAM, "ON")     # One state name
    #field(SCAN, "1 second")
    field(PINI, "1")
}


record(stringin, "$(Sys)$(Dev)Status")
{
	field(DTYP, "stream")
	field(DESC, "Status")
	field(INP,  "@COSCON_IS.proto ReadStatus($(Chan)) $(PORT)")
    #field(SCAN, "1 second")
    field(PINI, "1")
}

# Write 1 to switch to Standby mode
record(bo, "$(Sys)$(Dev)ModeSwitchToStandby")
{
    field(DESC, "Enable STANDBY mode")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
    field(VAL, 0)
    field(FLNK, "$(Sys)$(Dev)ModeSwitchToStandby_")
}

record(calcout, "$(Sys)$(Dev)ModeSwitchToStandby_")
{
    field(DTYP, "stream")
    field(DESC, "Switch to STANDBY command")
    field(INPA, "$(Sys)$(Dev)ModeSwitchToStandby")
    field(CALC, "A")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "@COSCON_IS.proto WriteSwitchToStandby($(Chan)) $(PORT)")
}


# Write 1 to switch to OFF mode
record(bo, "$(Sys)$(Dev)ModeSwitchToOff")
{
    field(DESC, "Enable OFF mode")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
    field(VAL, 0)
    field(FLNK, "$(Sys)$(Dev)ModeSwitchToOff_")
}

record(calcout, "$(Sys)$(Dev)ModeSwitchToOff_")
{
    field(DTYP, "stream")
    field(DESC, "Switch to OFF command")
    field(INPA, "$(Sys)$(Dev)ModeSwitchToOff")
    field(CALC, "A")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "@COSCON_IS.proto WriteSwitchToOff($(Chan)) $(PORT)")
}

