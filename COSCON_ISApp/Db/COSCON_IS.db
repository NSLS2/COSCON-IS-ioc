record(bo, "$(Sys)$(Dev)Init-Cmd")
{
    field(DTYP, "stream")
    field(DESC, "Init")
    field(OUT,  "@COSCON_IS.proto init($(Chan)) $(PORT)")
    field(PINI, "1")
}

# Voltage readback
record(ai, "$(Sys)$(Dev)V")
{
	field(DTYP, "stream")
	field(DESC, "Voltage")
	field(INP,  "@COSCON_IS.proto ReadV($(Chan)) $(PORT)")
	field(EGU,  "V")
	field(PREC, 3)
	field(SCAN, ".1 second")
}

# Current readback
record(ai, "$(Sys)$(Dev)I")
{
	field(DTYP, "stream")
	field(DESC, "Current")
	field(INP,  "@COSCON_IS.proto ReadI($(Chan)) $(PORT)")
	field(EGU,  "A")
	field(PREC, 3)
	field(SCAN, ".1 second")
}

# Voltage setpoint
record(ao, "$(Sys)$(Dev)V:SP")
{
	field(DTYP, "stream")
	field(DESC, "Voltage SP")
	field(OUT,  "@COSCON_IS.proto WriteVSP($(Chan)) $(PORT)")
	field(EGU,  "V")
	field(PREC, 3)
    field(PINI, "1")
    info(autosaveFields, "VAL")    
}

